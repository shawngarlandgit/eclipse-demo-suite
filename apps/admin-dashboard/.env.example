# Convex Configuration (Required)
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# Clerk Authentication (Required)
VITE_CLERK_PUBLISHABLE_KEY=pk_live_your-clerk-key

# Sentry Error Tracking (Optional - Production recommended)
# Get your DSN from https://sentry.io/settings/projects/{project}/keys/
VITE_SENTRY_DSN=https://your-dsn@sentry.io/project-id

# Application Configuration
VITE_APP_NAME=Cannabis Admin Dashboard
VITE_APP_ENV=development

# DO NOT set VITE_BYPASS_AUTH=true in production!
# VITE_BYPASS_AUTH=true  # Only for local development without Clerk

# DO NOT USE SUPABASE - This project uses Convex for backend
